---
title: "Protein Design Suite"
cluster:
  - rc
  - 2e


form:
  - app_type
  - auto_accounts
  - working_directory
  - bc_email_on_started
  # ── RFdiffusion ──────────────────────────────────────────────────────────
  - design_mode
  # Binder Design fields
  - target_chain
  - target_res_range
  - hotspot_res
  - binder_length_min
  - binder_length_max
  - noise_scale
  # Motif Scaffolding fields
  - motif_chain
  - motif_res_start
  - motif_res_end
  - nterm_min
  - nterm_max
  - cterm_min
  - cterm_max
  - scaffold_model
  # Partial Diffusion fields
  - struct_length
  - partial_t
  # Unconditional Generation fields
  - length_min
  - length_max
  # Symmetric Design fields
  - symmetry
  - sym_total_length
  - use_olig_contacts
  # Common RFdiffusion fields
  - pdb_structure
  - num_designs
  # ── BoltzGen ─────────────────────────────────────────────────────────────
  - boltz_protocol
  - boltz_target_file
  - boltz_target_chain
  - boltz_binding_site
  - boltz_binder_length_min
  - boltz_binder_length_max
  - boltz_num_designs
  - boltz_budget
  - boltz_small_mol_type
  - boltz_small_mol_id
  - boltz_design_mask
  - boltz_steps
  - boltz_reuse

attributes:

  # ── Shared ───────────────────────────────────────────────────────────────

  app_type:
    label: "Application"
    help: "Select the protein design tool to use"
    widget: select
    options:
      # rfdiffusion: hide all BoltzGen fields; show all RFdiffusion fields.
      # The data-hide-X: false rules here ensure mode-specific fields become
      # visible when switching back from BoltzGen. design_mode's rules then
      # hide whichever fields don't belong to the current mode (triggered by form.js).
      - ["RFdiffusion — diffusion-based de novo design", "rfdiffusion",
         data-hide-design-mode: false,
         data-hide-pdb-structure: false,
         data-hide-num-designs: false,
         data-hide-target-chain: false,
         data-hide-target-res-range: false,
         data-hide-hotspot-res: false,
         data-hide-binder-length-min: false,
         data-hide-binder-length-max: false,
         data-hide-noise-scale: false,
         data-hide-motif-chain: false,
         data-hide-motif-res-start: false,
         data-hide-motif-res-end: false,
         data-hide-nterm-min: false,
         data-hide-nterm-max: false,
         data-hide-cterm-min: false,
         data-hide-cterm-max: false,
         data-hide-scaffold-model: false,
         data-hide-struct-length: false,
         data-hide-partial-t: false,
         data-hide-length-min: false,
         data-hide-length-max: false,
         data-hide-symmetry: false,
         data-hide-sym-total-length: false,
         data-hide-use-olig-contacts: false,
         data-hide-boltz-protocol: true,
         data-hide-boltz-target-file: true,
         data-hide-boltz-target-chain: true,
         data-hide-boltz-binding-site: true,
         data-hide-boltz-binder-length-min: true,
         data-hide-boltz-binder-length-max: true,
         data-hide-boltz-num-designs: true,
         data-hide-boltz-budget: true,
         data-hide-boltz-small-mol-type: true,
         data-hide-boltz-small-mol-id: true,
         data-hide-boltz-design-mask: true,
         data-hide-boltz-steps: true,
         data-hide-boltz-reuse: true]
      # boltzgen: hide all RFdiffusion fields (mode-specific + common).
      # BoltzGen field visibility is controlled by boltz_protocol's data-hide rules.
      - ["BoltzGen — universal binder design", "boltzgen",
         data-hide-design-mode: true,
         data-hide-pdb-structure: true,
         data-hide-num-designs: true,
         data-hide-target-chain: true,
         data-hide-target-res-range: true,
         data-hide-hotspot-res: true,
         data-hide-binder-length-min: true,
         data-hide-binder-length-max: true,
         data-hide-noise-scale: true,
         data-hide-motif-chain: true,
         data-hide-motif-res-start: true,
         data-hide-motif-res-end: true,
         data-hide-nterm-min: true,
         data-hide-nterm-max: true,
         data-hide-cterm-min: true,
         data-hide-cterm-max: true,
         data-hide-scaffold-model: true,
         data-hide-struct-length: true,
         data-hide-partial-t: true,
         data-hide-length-min: true,
         data-hide-length-max: true,
         data-hide-symmetry: true,
         data-hide-sym-total-length: true,
         data-hide-use-olig-contacts: true,
         data-hide-boltz-protocol: false,
         data-hide-boltz-target-file: false,
         data-hide-boltz-target-chain: false,
         data-hide-boltz-binding-site: false,
         data-hide-boltz-binder-length-min: false,
         data-hide-boltz-binder-length-max: false,
         data-hide-boltz-num-designs: false,
         data-hide-boltz-budget: false,
         data-hide-boltz-small-mol-type: true,
         data-hide-boltz-small-mol-id: true,
         data-hide-boltz-design-mask: true,
         data-hide-boltz-steps: false,
         data-hide-boltz-reuse: false]
    value: "rfdiffusion"

  auto_accounts:
    label: "GPU Account"
    help: "Account with access to GPU resources (required)"
    required: true

  working_directory:
    label: "Working Directory"
    help: "Output files will be saved here (scratch space recommended)"
    widget: "path_selector"
    show_files: false
    value: "/scratch/<%= ENV['USER'] %>"

  bc_email_on_started:
    label: "Email Notifications"
    widget: check_box
    help: "Receive email notifications when the job starts and completes"

  # ── RFdiffusion ──────────────────────────────────────────────────────────

  design_mode:
    label: "Design Mode"
    help: "Select the RFdiffusion design mode"
    widget: select
    options:
      # Each option hides all fields that do NOT belong to that mode.
      # Fields for the current mode have no rule (they stay visible because
      # app_type=rfdiffusion already showed them via data-hide-X: false).
      - ["Binder Design", "binder",
         data-hide-motif-chain: true,
         data-hide-motif-res-start: true,
         data-hide-motif-res-end: true,
         data-hide-nterm-min: true,
         data-hide-nterm-max: true,
         data-hide-cterm-min: true,
         data-hide-cterm-max: true,
         data-hide-scaffold-model: true,
         data-hide-struct-length: true,
         data-hide-partial-t: true,
         data-hide-length-min: true,
         data-hide-length-max: true,
         data-hide-symmetry: true,
         data-hide-sym-total-length: true,
         data-hide-use-olig-contacts: true]
      - ["Motif Scaffolding", "scaffold",
         data-hide-target-chain: true,
         data-hide-target-res-range: true,
         data-hide-hotspot-res: true,
         data-hide-binder-length-min: true,
         data-hide-binder-length-max: true,
         data-hide-noise-scale: true,
         data-hide-struct-length: true,
         data-hide-partial-t: true,
         data-hide-length-min: true,
         data-hide-length-max: true,
         data-hide-symmetry: true,
         data-hide-sym-total-length: true,
         data-hide-use-olig-contacts: true]
      - ["Partial Diffusion", "partial",
         data-hide-target-chain: true,
         data-hide-target-res-range: true,
         data-hide-hotspot-res: true,
         data-hide-binder-length-min: true,
         data-hide-binder-length-max: true,
         data-hide-noise-scale: true,
         data-hide-motif-chain: true,
         data-hide-motif-res-start: true,
         data-hide-motif-res-end: true,
         data-hide-nterm-min: true,
         data-hide-nterm-max: true,
         data-hide-cterm-min: true,
         data-hide-cterm-max: true,
         data-hide-scaffold-model: true,
         data-hide-length-min: true,
         data-hide-length-max: true,
         data-hide-symmetry: true,
         data-hide-sym-total-length: true,
         data-hide-use-olig-contacts: true]
      - ["Unconditional Generation", "unconditional",
         data-hide-target-chain: true,
         data-hide-target-res-range: true,
         data-hide-hotspot-res: true,
         data-hide-binder-length-min: true,
         data-hide-binder-length-max: true,
         data-hide-noise-scale: true,
         data-hide-motif-chain: true,
         data-hide-motif-res-start: true,
         data-hide-motif-res-end: true,
         data-hide-nterm-min: true,
         data-hide-nterm-max: true,
         data-hide-cterm-min: true,
         data-hide-cterm-max: true,
         data-hide-scaffold-model: true,
         data-hide-struct-length: true,
         data-hide-partial-t: true,
         data-hide-symmetry: true,
         data-hide-sym-total-length: true,
         data-hide-use-olig-contacts: true]
      - ["Symmetric Design", "symmetric",
         data-hide-target-chain: true,
         data-hide-target-res-range: true,
         data-hide-hotspot-res: true,
         data-hide-binder-length-min: true,
         data-hide-binder-length-max: true,
         data-hide-noise-scale: true,
         data-hide-motif-chain: true,
         data-hide-motif-res-start: true,
         data-hide-motif-res-end: true,
         data-hide-nterm-min: true,
         data-hide-nterm-max: true,
         data-hide-cterm-min: true,
         data-hide-cterm-max: true,
         data-hide-scaffold-model: true,
         data-hide-struct-length: true,
         data-hide-partial-t: true,
         data-hide-length-min: true,
         data-hide-length-max: true]

  # ── RFdiffusion: Binder Design ────────────────────────────────────────────

  target_chain:
    widget: text_field
    label: "Target Chain ID"
    help: "Chain letter in your PDB for the target protein (e.g. <code>A</code>)."
    placeholder: "e.g. A"
    required: true

  target_res_range:
    widget: text_field
    label: "Target Residue Range (optional)"
    help: "Residues to include as target, in PDB numbering (e.g. <code>1-150</code>). Leave blank to use the entire chain."
    placeholder: "e.g. 1-150"

  hotspot_res:
    widget: text_field
    label: "Hotspot Residues (strongly recommended)"
    help: "Key residues on the target that should drive binding — chain letter + residue number, comma-separated (e.g. <code>A59,A83,A91</code>). Omitting hotspots significantly reduces success rate."
    placeholder: "e.g. A59,A83,A91"

  binder_length_min:
    widget: number_field
    label: "Binder Min Length (residues)"
    help: "Minimum length of the designed binder. Typical range: 50–150."
    min: 20
    max: 400
    value: 70

  binder_length_max:
    widget: number_field
    label: "Binder Max Length (residues)"
    help: "Maximum length (exact length is randomly sampled each design)."
    min: 20
    max: 400
    value: 100

  noise_scale:
    widget: select
    label: "Noise Scale"
    help: "Lower noise improves design quality at the cost of diversity. Recommended: Zero noise for binder design."
    options:
      - ["Zero noise — maximum quality (recommended)", "0"]
      - ["Reduced noise — balanced (0.5)", "0.5"]
      - ["Standard noise — maximum diversity (1.0)", "1.0"]
    value: "0"

  # ── RFdiffusion: Motif Scaffolding ────────────────────────────────────────

  motif_chain:
    widget: text_field
    label: "Motif Chain ID"
    help: "Chain letter containing the functional motif to preserve (e.g. <code>A</code>)."
    placeholder: "e.g. A"
    required: true

  motif_res_start:
    widget: number_field
    label: "Motif Start Residue"
    help: "First residue of the motif in PDB numbering (e.g. <code>163</code>)."
    min: 1
    placeholder: "e.g. 163"
    required: true

  motif_res_end:
    widget: number_field
    label: "Motif End Residue"
    help: "Last residue of the motif, inclusive (e.g. <code>181</code>)."
    min: 1
    placeholder: "e.g. 181"
    required: true

  nterm_min:
    widget: number_field
    label: "N-terminal Min (residues)"
    help: "Minimum designed residues before the motif."
    min: 0
    max: 300
    value: 10

  nterm_max:
    widget: number_field
    label: "N-terminal Max (residues)"
    help: "Maximum designed residues before the motif."
    min: 0
    max: 300
    value: 40

  cterm_min:
    widget: number_field
    label: "C-terminal Min (residues)"
    help: "Minimum designed residues after the motif."
    min: 0
    max: 300
    value: 10

  cterm_max:
    widget: number_field
    label: "C-terminal Max (residues)"
    help: "Maximum designed residues after the motif."
    min: 0
    max: 300
    value: 40

  scaffold_model:
    widget: select
    label: "Checkpoint"
    help: "Use <strong>Active Site</strong> for tiny/sparse motifs (1–3 residues or catalytic triads). Use <strong>Standard</strong> for larger contiguous motifs."
    options:
      - ["Standard — for contiguous motifs (Base model)", "base"]
      - ["Active Site — for small/sparse catalytic motifs", "active_site"]
    value: "base"

  # ── RFdiffusion: Partial Diffusion ────────────────────────────────────────

  struct_length:
    widget: number_field
    label: "Total Structure Length (residues)"
    help: "Total residue count in your input PDB (all chains combined). <strong>This must match exactly.</strong> Open your PDB in a viewer and count residues, or run <code>grep -c \"^ATOM\" yourfile.pdb</code>."
    min: 1
    placeholder: "e.g. 79"
    required: true

  partial_t:
    widget: number_field
    label: "Noise Steps"
    help: "How many diffusion steps to apply (1–50). Lower = more conservative changes, closer to input. Recommended: <strong>10</strong> (~20% noise). Use 20–40 for larger changes."
    min: 1
    max: 50
    value: 10
    required: true

  # ── RFdiffusion: Unconditional Generation ─────────────────────────────────

  length_min:
    widget: number_field
    label: "Min Protein Length (residues)"
    help: "Minimum length of the generated protein."
    min: 50
    max: 800
    value: 100
    required: true

  length_max:
    widget: number_field
    label: "Max Protein Length (residues)"
    help: "Maximum length (exact length is randomly sampled each design). Proteins up to ~300 residues are typical."
    min: 50
    max: 800
    value: 200
    required: true

  # ── RFdiffusion: Symmetric Design ─────────────────────────────────────────

  symmetry:
    widget: select
    label: "Symmetry Type"
    help: "The cyclic (Cn) or dihedral (Dn) symmetry of the designed oligomer. Tetrahedral/Octahedral/Icosahedral generate 12/24/60-mers."
    options:
      - ["C2 — homodimer (2-fold)", "C2"]
      - ["C3 — homotrimer (3-fold)", "C3"]
      - ["C4 — homotetramer (4-fold)", "C4"]
      - ["C5 — homopentamer (5-fold)", "C5"]
      - ["C6 — homohexamer (6-fold)", "C6"]
      - ["D2 — dihedral (4 chains)", "D2"]
      - ["D3 — dihedral (6 chains)", "D3"]
      - ["Tetrahedral (12 chains)", "tetrahedral"]
      - ["Octahedral (24 chains)", "octahedral"]
      - ["Icosahedral (60 chains)", "icosahedral"]
    value: "C3"

  sym_total_length:
    widget: number_field
    label: "Total Assembly Length (residues)"
    help: "Total residues across <em>all subunits combined</em>. Must be evenly divisible by the number of chains (e.g. for C6 with 80 residues per chain: enter <code>480</code>)."
    min: 50
    max: 10000
    value: 300
    required: true

  use_olig_contacts:
    widget: check_box
    label: "Apply oligomer contact potential (recommended)"
    help: "Guides chains to form both intra- and inter-chain contacts during diffusion. Strongly recommended for oligomer design."

  # ── RFdiffusion: Common ───────────────────────────────────────────────────

  pdb_structure:
    widget: path_selector
    label: "Input PDB File"
    help: "PDB file from HPC storage. Required for Binder, Scaffold, Partial, and Symmetric modes. Optional for Unconditional — if omitted, RFdiffusion uses an internal default structure (the PDB is loaded but the structure is not used to condition de novo generation)."
    required: false
    directory: false
    show_files: true

  num_designs:
    widget: number_field
    label: "Number of Designs"
    help: "How many independent protein designs to generate (1–100). Start with 10 to test, scale up for production."
    min: 1
    max: 100
    value: 10
    required: true

  # ── BoltzGen ─────────────────────────────────────────────────────────────

  boltz_protocol:
    label: "Protocol"
    help: "Design protocol — determines what molecule type to design and which pipeline steps run"
    widget: select
    options:
      - ["Protein binder (protein-anything)", "protein-anything",
         data-hide-boltz-small-mol-type: true,
         data-hide-boltz-small-mol-id: true,
         data-hide-boltz-design-mask: true,
         data-hide-boltz-binder-length-min: false,
         data-hide-boltz-binder-length-max: false,
         data-hide-boltz-binding-site: false]
      - ["Peptide / cyclic binder (peptide-anything)", "peptide-anything",
         data-hide-boltz-small-mol-type: true,
         data-hide-boltz-small-mol-id: true,
         data-hide-boltz-design-mask: true,
         data-hide-boltz-binder-length-min: false,
         data-hide-boltz-binder-length-max: false,
         data-hide-boltz-binding-site: false]
      - ["Protein → small molecule (protein-small_molecule)", "protein-small_molecule",
         data-hide-boltz-small-mol-type: false,
         data-hide-boltz-small-mol-id: false,
         data-hide-boltz-design-mask: true,
         data-hide-boltz-binder-length-min: false,
         data-hide-boltz-binder-length-max: false,
         data-hide-boltz-binding-site: true]
      - ["Nanobody CDRs (nanobody-anything)", "nanobody-anything",
         data-hide-boltz-small-mol-type: true,
         data-hide-boltz-small-mol-id: true,
         data-hide-boltz-design-mask: true,
         data-hide-boltz-binder-length-min: false,
         data-hide-boltz-binder-length-max: false,
         data-hide-boltz-binding-site: false]
      - ["Antibody CDRs (antibody-anything)", "antibody-anything",
         data-hide-boltz-small-mol-type: true,
         data-hide-boltz-small-mol-id: true,
         data-hide-boltz-design-mask: true,
         data-hide-boltz-binder-length-min: false,
         data-hide-boltz-binder-length-max: false,
         data-hide-boltz-binding-site: false]
      - ["Protein redesign / optimization (protein-redesign)", "protein-redesign",
         data-hide-boltz-small-mol-type: true,
         data-hide-boltz-small-mol-id: true,
         data-hide-boltz-design-mask: false,
         data-hide-boltz-binder-length-min: true,
         data-hide-boltz-binder-length-max: true,
         data-hide-boltz-binding-site: true]

  boltz_target_file:
    widget: path_selector
    label: "Target Structure File"
    help: "PDB or mmCIF file of the target protein. For protein-small_molecule this is optional (the target is the ligand)."
    required: false
    directory: false
    show_files: true

  boltz_target_chain:
    widget: text_field
    label: "Target Chain ID"
    help: "Chain ID(s) in the target file to include (e.g. A). Leave blank to include all chains."
    placeholder: "e.g. A"

  boltz_binding_site:
    widget: text_field
    label: "Binding Site Residues (optional)"
    help: "Residue indices on the target chain that the design should bind. Uses label_seq_id numbering starting at 1 (e.g. 343,344,251 or 10..30). Leave blank to bind anywhere."
    placeholder: "e.g. 343,344,251"

  boltz_binder_length_min:
    widget: number_field
    label: "Binder Min Length (residues)"
    help: "Minimum number of residues in the designed binder"
    min: 5
    max: 500
    value: 50

  boltz_binder_length_max:
    widget: number_field
    label: "Binder Max Length (residues)"
    help: "Maximum number of residues in the designed binder"
    min: 5
    max: 500
    value: 100

  boltz_num_designs:
    widget: number_field
    label: "Number of Intermediate Designs"
    help: "Intermediate designs to generate before filtering (50 to test, 10 000–60 000 for production)"
    min: 1
    max: 100000
    value: 100

  boltz_budget:
    widget: number_field
    label: "Final Design Budget"
    help: "Number of designs in the final diversity-optimized output set"
    min: 1
    max: 1000
    value: 10

  boltz_small_mol_type:
    label: "Small Molecule ID Type"
    help: "How the small molecule target is specified"
    widget: select
    options:
      - ["CCD code (e.g. ATP)", "ccd"]
      - ["SMILES string", "smiles"]

  boltz_small_mol_id:
    widget: text_field
    label: "Small Molecule Identifier"
    help: "CCD code (e.g. ATP) or SMILES string of the target ligand"
    placeholder: "e.g. ATP"

  boltz_design_mask:
    widget: text_field
    label: "Residues to Redesign"
    help: "For protein-redesign: label_seq_id residue indices to redesign on the target chain (e.g. 14..19,25). Leave blank to redesign the entire chain."
    placeholder: "e.g. 14..19,25"

  boltz_steps:
    label: "Pipeline Steps"
    help: "Which BoltzGen pipeline steps to run"
    widget: select
    options:
      - ["Full pipeline — design → inverse folding → folding → analysis → filtering", "all"]
      - ["Design + inverse folding only", "design inverse_folding"]
      - ["Design only", "design"]
      - ["Rerun filtering on existing output", "filtering"]

  boltz_reuse:
    label: "Resume Previous Run"
    widget: check_box
    help: "Reuse existing intermediate results so an interrupted run continues without repeating completed steps"
