#!/bin/bash
# ── Status helpers ────────────────────────────────────────────────────────────

update_status() {
    local progress=$1
    local output=$2
    local phase=$3
    shift 3
    local detail=("$@")

    if [ ${#detail[@]} -eq 0 ]; then
        detail_json="[]"
    else
        detail_json="["
        for item in "${detail[@]}"; do
            detail_json+="\"${item//\"/\\\"}\","
        done
        detail_json="${detail_json%,}]"
    fi

    echo "{\"progress\": \"$progress\", \"status\": \"$output\", \"phase\": \"$phase\", \"detail\": $detail_json}" \
        | tee "${STATUS_FILE}"
}

wait_for_job_and_log() {
    local job_id=$1
    local logfile=$2

    update_status 0 "Waiting for job ${job_id} to start..." "Queued"
    while ! squeue -j "$job_id" > /dev/null 2>&1; do
        sleep 5
    done
    while [ ! -f "$logfile" ]; do
        sleep 5
    done
}

# ── RFdiffusion monitor ────────────────────────────────────────────────────────
# Counts "Finished design in" lines vs NUM_DESIGNS to give accurate per-design
# progress. Milestones from real rfdiffusion log output observed in testing.
monitor_rf_log() {
    local logfile=$1
    local job_id=$2
    local phase="RFdiffusion — Protein Design"
    local -a details=()

    update_status 0 "Initializing RFdiffusion job..." "$phase"

    while true; do
        local progress=0
        local step="Starting up"

        if [ -f "$logfile" ]; then
            # ── Startup milestones ──────────────────────────────────────────
            grep -q "Found GPU with device_name"  "$logfile" 2>/dev/null && { step="GPU detected";           progress=3;  }
            grep -q "Reading models from"          "$logfile" 2>/dev/null && { step="Loading model weights"; progress=6;  }
            grep -q "Reading checkpoint from"      "$logfile" 2>/dev/null && { step="Loading checkpoint";    progress=9;  }
            grep -q "Loading checkpoint\."         "$logfile" 2>/dev/null && { step="Checkpoint loaded";     progress=12; }
            grep -q "Successful diffuser __init__" "$logfile" 2>/dev/null && { step="Diffusion model ready"; progress=15; }

            # ── Per-design progress ─────────────────────────────────────────
            # 15 → 95 % spread across all designs
            local finished
            finished=$(grep -c "Finished design in" "$logfile" 2>/dev/null || echo 0)

            if [ "$finished" -gt 0 ] && [ "${NUM_DESIGNS:-1}" -gt 0 ]; then
                progress=$(( 15 + finished * 80 / NUM_DESIGNS ))
                step="${finished} / ${NUM_DESIGNS} designs complete"

                # Rebuild detail list from log
                details=()
                while IFS= read -r line; do
                    local mins
                    mins=$(echo "$line" | grep -o '[0-9.]\+ minutes')
                    details+=("Design $((${#details[@]} + 1)) done (${mins})")
                done < <(grep "Finished design in" "$logfile" 2>/dev/null)

            elif grep -q "Making design" "$logfile" 2>/dev/null; then
                step="Diffusion in progress..."
                progress=18
            fi
        fi

        update_status "$progress" "$step" "$phase" "${details[@]}"

        # ── Completion marker ───────────────────────────────────────────────
        # "=== Done at" is printed by the SLURM script after singularity exits.
        if grep -q "=== Done at" "$logfile" 2>/dev/null; then
            local finished
            finished=$(grep -c "Finished design in" "$logfile" 2>/dev/null || echo 0)
            local msg="${finished} / ${NUM_DESIGNS} designs complete"
            [ "$finished" -ge "${NUM_DESIGNS:-1}" ] && msg="All ${NUM_DESIGNS} designs complete!"
            update_status 100 "$msg" "$phase" "${details[@]}"
            break
        fi

        # ── Done when job leaves R state ───────────────────────────────────
        local job_state
        job_state=$(squeue -j "$job_id" -h -o %t 2>/dev/null)
        if [ "$job_state" != "R" ]; then
            break
        fi

        sleep 5
    done
}

# ── BoltzGen monitor ──────────────────────────────────────────────────────────
# Tracks the 5-step BoltzGen pipeline using real log strings.
# Each pipeline step contributes a defined slice of the 0-100% range.
monitor_boltz_log() {
    local logfile=$1
    local job_id=$2
    local phase="BoltzGen — Binder Design"
    local -a details=()

    update_status 0 "Initializing BoltzGen job..." "$phase"

    while true; do
        local progress=0
        local step="Starting up"
        # Rebuild details from scratch each poll so entries never duplicate
        local -a details=()

        if [ -f "$logfile" ]; then
            # ── Configuration phase (outer boltzgen process, fresh runs only) ─
            grep -q "Configuring pipeline"   "$logfile" 2>/dev/null && { step="Configuring pipeline"; progress=5;  }
            grep -q "Configuration complete" "$logfile" 2>/dev/null && { step="Pipeline configured";  progress=10; details+=("Pipeline configured"); }
            grep -q "Executing pipeline"     "$logfile" 2>/dev/null && { step="Executing pipeline";   progress=12; }

            # ── Pipeline steps ──────────────────────────────────────────────
            # BoltzGen steps: design, inverse_folding, folding, design_folding, analysis, filtering
            #
            # Steps 1-4 emit "[Step X/N] stepname - tqdm" in real-time from subprocesses.
            # Steps 5-6 (analysis, filtering) don't emit [Step X/N] tqdm prefixes — instead
            # they emit unique subprocess output lines we grep for directly.
            # The outer "Pipeline step X of Y" messages are buffered stdout that only
            # flush at the very end, so we can't rely on them mid-run for steps 5+6.
            #
            # "Done" messages are only added in the completion block so the last step
            # always gets its done entry regardless of how many steps ran.
            local s1=0 s2=0 s3=0 s4=0 s5=0 s6=0
            grep -qE "Pipeline step 1|\[Step 1/[0-9]+\]" "$logfile" 2>/dev/null && { step="Step 1: Design";        progress=15; s1=1; }
            grep -qE "Pipeline step 2|\[Step 2/[0-9]+\]" "$logfile" 2>/dev/null && { step="Step 2: Inverse folding"; progress=35; s2=1; }
            grep -qE "Pipeline step 3|\[Step 3/[0-9]+\]" "$logfile" 2>/dev/null && { step="Step 3: Folding";         progress=55; s3=1; }
            grep -qE "Pipeline step 4|\[Step 4/[0-9]+\]" "$logfile" 2>/dev/null && { step="Step 4: Design folding";  progress=70; s4=1; }
            grep -qE "Pipeline step 5|Processing samples:" "$logfile" 2>/dev/null && { step="Step 5: Analysis";      progress=84; s5=1; }
            grep -qE "Pipeline step 6|lazy greedy diversity|copy top design files" "$logfile" 2>/dev/null && { step="Step 6: Filtering"; progress=93; s6=1; }

            # ── Fine-grained design step sub-progress ───────────────────────
            if [ "$s1" -eq 1 ] && [ "$s2" -eq 0 ]; then
                local done_count total_count
                done_count=$(grep -o '[0-9]\+/[0-9]\+' "$logfile" 2>/dev/null | tail -1 | cut -d/ -f1)
                total_count=$(grep -o '[0-9]\+/[0-9]\+' "$logfile" 2>/dev/null | tail -1 | cut -d/ -f2)
                if [ -n "$done_count" ] && [ -n "$total_count" ] && [ "$total_count" -gt 0 ]; then
                    local design_pct=$(( done_count * 20 / total_count ))
                    progress=$(( 15 + design_pct ))
                    step="Step 1: Design diffusion (${done_count}/${total_count})"
                fi
            fi

            # ── Completion ───────────────────────────────────────────────────
            # Build the full done history here so the last step always gets its
            # "done" entry regardless of how many steps were in the pipeline.
            grep -q "=== Done at" "$logfile" 2>/dev/null && {
                step="Pipeline complete"
                progress=100
                [ "$s1" -eq 1 ] && details+=("Step 1: Design done")
                [ "$s2" -eq 1 ] && details+=("Step 2: Inverse folding done")
                [ "$s3" -eq 1 ] && details+=("Step 3: Folding done")
                [ "$s4" -eq 1 ] && details+=("Step 4: Design folding done")
                [ "$s5" -eq 1 ] && details+=("Step 5: Analysis done")
                [ "$s6" -eq 1 ] && details+=("Step 6: Filtering done")
                details+=("All steps complete")
            }
        fi

        update_status "$progress" "$step" "$phase" "${details[@]}"

        local job_state
        job_state=$(squeue -j "$job_id" -h -o %t 2>/dev/null)
        if [ "$job_state" != "R" ]; then
            grep -q "=== Done at" "$logfile" 2>/dev/null && \
                update_status 100 "Pipeline complete" "$phase" "${details[@]}"
            break
        fi

        sleep 5
    done
}

# ── Dispatch ───────────────────────────────────────────────────────────────────
if [ "${APP_TYPE}" = "rfdiffusion" ]; then
    wait_for_job_and_log "${DIFFUSION_JOB_ID}" "${DIFFUSION_LOG_FILE}"
    monitor_rf_log       "${DIFFUSION_LOG_FILE}" "${DIFFUSION_JOB_ID}"
else
    wait_for_job_and_log "${BOLTZ_JOB_ID}" "${BOLTZ_LOG_FILE}"
    monitor_boltz_log    "${BOLTZ_LOG_FILE}" "${BOLTZ_JOB_ID}"
fi
